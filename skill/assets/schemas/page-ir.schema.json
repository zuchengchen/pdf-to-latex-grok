{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "pdf-to-latex/page-ir-shard.schema.json",
  "title": "PDF-to-LaTeX page IR shard",
  "description": "Version 1 stores detailed page arrays inline; version 2 stores compact page counts and a detail artifact.",
  "oneOf": [
    {"$ref": "#/$defs/legacy-shard"},
    {"$ref": "#/$defs/compact-shard"}
  ],
  "$defs": {
    "common-shard": {
      "type": "object",
      "required": [
        "schema_version",
        "kind",
        "batch_id",
        "source",
        "owned_pages",
        "context_pages",
        "pages",
        "artifacts",
        "status"
      ],
      "properties": {
        "schema_version": {"type": "integer"},
        "kind": {"const": "page-ir-shard"},
        "batch_id": {
          "type": "string",
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]*$"
        },
        "source": {
          "type": "object",
          "required": ["sha256", "size_bytes", "page_count"],
          "properties": {
            "path": {"type": "string"},
            "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
            "size_bytes": {"type": "integer", "minimum": 1},
            "page_count": {"type": "integer", "minimum": 1}
          },
          "additionalProperties": true
        },
        "owned_pages": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {"type": "integer", "minimum": 1}
        },
        "context_pages": {
          "type": "array",
          "uniqueItems": true,
          "items": {"type": "integer", "minimum": 1}
        },
        "style_profile_sha256": {
          "type": "string",
          "pattern": "^[0-9a-f]{64}$"
        },
        "document_ir_sha256": {
          "type": "string",
          "pattern": "^[0-9a-f]{64}$"
        },
        "pages": {"type": "array", "minItems": 1},
        "artifacts": {
          "type": "array",
          "items": {"type": "string", "minLength": 1}
        },
        "reason": {"type": "string"},
        "next_action": {"type": "string"},
        "created_at": {"type": "string"},
        "usage": {
          "type": "object",
          "properties": {
            "input_tokens": {"type": "integer", "minimum": 0},
            "output_tokens": {"type": "integer", "minimum": 0},
            "cached_input_tokens": {"type": "integer", "minimum": 0},
            "reasoning_tokens": {"type": "integer", "minimum": 0},
            "duration_ms": {"type": "integer", "minimum": 0},
            "retry_count": {"type": "integer", "minimum": 0}
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": true
    },
    "status": {
      "enum": [
        "pending",
        "in-progress",
        "rebuilt",
        "blocked",
        "omitted-with-reason"
      ]
    },
    "legacy-page": {
      "type": "object",
      "required": [
        "page",
        "route",
        "status",
        "blocks",
        "objects",
        "continuity",
        "uncertainties"
      ],
      "properties": {
        "page": {"type": "integer", "minimum": 1},
        "route": {"type": "string", "minLength": 1},
        "status": {"$ref": "#/$defs/status"},
        "blocks": {"type": "array"},
        "objects": {"type": "array"},
        "continuity": {"type": "array"},
        "uncertainties": {"type": "array"},
        "target": {"type": "string"}
      },
      "additionalProperties": true
    },
    "compact-page": {
      "type": "object",
      "required": [
        "page",
        "route",
        "status",
        "block_count",
        "object_count",
        "continuity_count",
        "uncertainty_count"
      ],
      "properties": {
        "page": {"type": "integer", "minimum": 1},
        "route": {"type": "string", "minLength": 1},
        "status": {"$ref": "#/$defs/status"},
        "block_count": {"type": "integer", "minimum": 0},
        "object_count": {"type": "integer", "minimum": 0},
        "continuity_count": {"type": "integer", "minimum": 0},
        "uncertainty_count": {"type": "integer", "minimum": 0},
        "target": {"type": "string"}
      },
      "additionalProperties": true
    },
    "worker-summary": {
      "type": "object",
      "required": ["text", "owned_page_count", "blocked_page_count", "uncertain_page_count"],
      "properties": {
        "text": {"type": "string", "minLength": 1, "maxLength": 1200},
        "owned_page_count": {"type": "integer", "minimum": 1},
        "blocked_page_count": {"type": "integer", "minimum": 0},
        "uncertain_page_count": {"type": "integer", "minimum": 0}
      },
      "additionalProperties": false
    },
    "legacy-shard": {
      "allOf": [
        {"$ref": "#/$defs/common-shard"},
        {
          "type": "object",
          "properties": {
            "schema_version": {"const": 1},
            "pages": {
              "type": "array",
              "minItems": 1,
              "items": {"$ref": "#/$defs/legacy-page"}
            }
          }
        }
      ]
    },
    "compact-shard": {
      "allOf": [
        {"$ref": "#/$defs/common-shard"},
        {
          "type": "object",
          "required": ["worker_summary", "detail_artifact"],
          "properties": {
            "schema_version": {"const": 2},
            "pages": {
              "type": "array",
              "minItems": 1,
              "items": {"$ref": "#/$defs/compact-page"}
            },
            "artifacts": {"minItems": 1},
            "worker_summary": {"$ref": "#/$defs/worker-summary"},
            "detail_artifact": {"type": "string", "minLength": 1}
          }
        }
      ]
    }
  }
}
