        ]
      },
      "require_gates": [
        "source-fidelity-review"
      ]
    },
    {
      "id": "publication-source-aware-repair-gates",
      "when": {
        "operation": [
          "repair"
        ],
        "delivery_level": [
          "publication-polish"
        ],
        "verification_scope": [
          "source-aware"
        ]
      },
      "require_gates": [
        "source-fidelity-review"
      ]
    },
    {
      "id": "publication-gates",
      "when": {
        "operation": [
          "convert",
          "resume",
          "refine",
          "review"
        ],
        "delivery_level": [
          "publication-polish"
        ]
      },
      "require_gates": [
        "artifact-scan",
        "clean-room-build",
        "publication-review"
      ]
    },
    {
      "id": "publication-repair-gates",
      "when": {
        "operation": [
          "repair"
        ],
        "delivery_level": [
          "publication-polish"
        ]
      },
      "require_gates": [
        "workflow-setup",
        "build-verification",
        "final-state-review",
        "repair-verification",
        "artifact-scan",
        "clean-room-build",
        "publication-review"
      ]
    },
    {
      "id": "book-gates",
      "when": {
        "operation": [
          "convert",
          "resume",
          "refine",
          "review"
        ],
        "traits_any": [
          "book"
