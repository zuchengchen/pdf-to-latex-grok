  "gate_rules": [
    {
      "id": "stateful-base",
      "when": {
        "operation": [
          "convert",
          "resume",
          "refine"
        ]
      },
      "require_gates": [
        "workflow-setup",
        "build-verification",
        "final-state-review"
      ]
    },
    {
      "id": "durable-repair-base",
      "when": {
        "operation": [
          "repair"
        ],
        "execution_mode": [
          "resumable",
          "goal-backed"
        ]
      },
      "require_gates": [
        "workflow-setup",
        "build-verification",
        "final-state-review"
      ]
    },
    {
      "id": "convert-gates",
      "when": {
        "operation": [
          "convert"
        ]
      },
      "require_gates": [
        "source-analysis",
        "semantic-reconstruction"
      ]
    },
    {
      "id": "resume-gates",
      "when": {
        "operation": [
          "resume"
        ]
      },
